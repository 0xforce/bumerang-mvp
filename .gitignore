# =============================================================================
# Bumerang — Enterprise .gitignore (Next.js + Supabase + pnpm)
# =============================================================================

# -----------------------------------------------------------------------------
# Security & secrets — NEVER commit real credentials
# -----------------------------------------------------------------------------
# Covers: .env, .env.local, .env.development, .env.production, .env.*.local, etc.
.env
.env.*
!.env.example

# direnv / dotenvx / local key material
.envrc
.env.keys

# -----------------------------------------------------------------------------
# Supabase (CLI local dev — matches supabase/.gitignore; listed here for clarity)
# -----------------------------------------------------------------------------
supabase/.temp/
supabase/.branches/

# -----------------------------------------------------------------------------
# Dependencies & package managers
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# pnpm
.pnpm-debug.log*
pnpm-debug.log*

# npm / yarn (if ever used)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Next.js & build outputs
# -----------------------------------------------------------------------------
.next/
out/
build/
dist/

# Vercel
.vercel

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# TypeScript / tooling caches
# -----------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo
.eslintcache

# -----------------------------------------------------------------------------
# Misc generated / local
# -----------------------------------------------------------------------------
*.pem

# -----------------------------------------------------------------------------
# IDE — VS Code / Cursor
# -----------------------------------------------------------------------------
# Track shared editor config only; ignore personal workspace state.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Cursor (local agent/MCP/cache). Uncomment to version team rules:
# !.cursor/rules/
.cursor/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Optional / future — safe to keep (no-op if unused)
# -----------------------------------------------------------------------------
# Playwright / E2E
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Storybook
storybook-static/

# Turborepo (monorepo or future)
.turbo/
